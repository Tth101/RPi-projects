FROM golang:1.24-alpine AS builder

WORKDIR /PiDashboard/src

# Copy dependency files first (better layer caching)
COPY src/go.mod src/go.sum ./

RUN go mod download

# Copy only the Go source files
COPY src/ ./

RUN CGO_ENABLED=0 GOOS=linux GOARCH=arm64 go build -o server .

FROM alpine:3.21 AS final

WORKDIR /PiDashboard

# Copy ONLY the compiled binary from the builder stage
COPY --from=builder /PiDashboard/src/server ./server

# Copy static assets, certs and config from build context
COPY static/ ./static/
COPY certs/ ./certs/
COPY URLs.yaml .

EXPOSE 8080

CMD ["./server"]